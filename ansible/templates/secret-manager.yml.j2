agent:
  nodeName: "{{ secret_manager_agent_node_name }}"
  trustedRoots:
    - "{{ secret_manager_work_dir }}"

server:
  port: {{ secret_manager_port }}

logging:
  level: "{{ secret_manager_logging_level }}"
  format: "{{ secret_manager_logging_format }}"
  auditFile: "{{ secret_manager_logging_audit_file }}"

database:
  type: "{{ secret_manager_db_type }}"
  path: "{{ secret_manager_db_path }}"

security:
  tls:
    enabled: {{ secret_manager_tls_enabled }}
    certFile: "{{ secret_manager_tls_cert_file | default('') }}"
    keyFile: "{{ secret_manager_tls_key_file | default('') }}"
    clientCAFile: "{{ secret_manager_tls_client_ca_file | default('') }}"
  auth:
    method: "{{ secret_manager_auth_method }}"
    jwt:
      secret: "{{ secret_manager_jwt_secret | default('') }}"
      jwksUrl: "{{ secret_manager_jwt_jwks_url | default('') }}"
      issuer: "{{ secret_manager_jwt_issuer | default('') }}"
      audience: "{{ secret_manager_jwt_audience | default('') }}"
    spire:
      socketPath: "{{ secret_manager_spire_socket_path | default('') }}"
      trustDomain: "{{ secret_manager_spire_trust_domain | default('') }}"
      allowedSpiffeIds: {{ secret_manager_spire_allowed_spiffe_ids | default([]) }}