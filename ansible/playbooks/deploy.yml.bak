---
# Main playbook for deploying Secret Manager
- name: Deploy Secret Manager
  hosts: install
  become: yes
  gather_facts: yes
  
  vars_files:
    - group_vars/all.yml
  
  handlers:
    - name: Restart Secret Manager service
      service:
        name: "{{ secret_manager_service_name }}"
        state: restarted
        enabled: yes

  tasks:
    # Pre-flight Checks
    - name: Verify Python is installed
      ansible.builtin.command: python3 --version
      register: python_check
      failed_when: false
      changed_when: false

    - name: Install required dependencies
      ansible.builtin.apt:
        name: "{{ need_packages }}"
        state: present
        update_cache: yes
      when: ansible_os_family == "Debian"

    # Create user and directories
    - name: Create secret-manager user
      ansible.builtin.user:
        name: "{{ secret_manager_service_user }}"
        system: yes
        shell: /bin/false
        home: "{{ secret_manager_work_dir }}"
        create_home: false
      when: secret_manager_service_user != "root"

    - name: Create necessary directories
      ansible.builtin.file:
        path: "{{ item }}"
        state: directory
        mode: '0755'
        owner: "{{ secret_manager_service_user if secret_manager_service_user != 'root' else 'root' }}"
        group: "{{ secret_manager_service_group if secret_manager_service_group else secret_manager_service_user }}"
      loop:
        - "{{ secret_manager_work_dir }}"
        - "{{ secret_manager_config_dir }}"
        - "{{ secret_manager_log_dir }}"
        - "{{ secret_manager_data_dir }}"

    # Download and install binary
    - name: Get latest release URL
      ansible.builtin.uri:
        url: "{{ secret_manager_release_url }}"
        return_content: yes
        method: GET
      register: release_info
      when: secret_manager_version == "latest"

    - name: Extract download URL from release info
      ansible.builtin.set_fact:
        download_url: "{{ release_info.json.assets | selectattr('name', 'search', secret_manager_binary_name) | map(attribute='browser_download_url') | list | first }}"
      when: secret_manager_version == "latest"

    - name: Use specific version if provided
      ansible.builtin.set_fact:
        download_url: "https://github.com/{{ secret_manager_repo }}/releases/download/v{{ secret_manager_version }}/secret-manager-linux-amd64"
      when: secret_manager_version != "latest"

    - name: Download Secret Manager binary
      ansible.builtin.get_url:
        url: "{{ download_url }}"
        dest: "/tmp/{{ secret_manager_binary_name }}"
        mode: '0755'
        owner: "{{ secret_manager_service_user if secret_manager_service_user != 'root' else 'root' }}"

    - name: Move binary to install location
      ansible.builtin.copy:
        src: "/tmp/{{ secret_manager_binary_name }}"
        dest: "{{ secret_manager_work_dir }}/secret-manager"
        mode: '0755'
        remote_src: yes
        owner: "{{ secret_manager_service_user if secret_manager_service_user != 'root' else 'root' }}"

    # Install Systemd service
    - name: Create Systemd service file
      ansible.builtin.template:
        src: secret-manager.service.j2
        dest: "/etc/systemd/system/{{ secret_manager_service_name }}.service"
        mode: '0644'
        owner: root
        group: root
      notify: Restart Secret Manager service

    - name: Reload systemd daemon
      ansible.builtin.systemd:
        daemon_reload: yes
      notify: Restart Secret Manager service

    # Create configuration file
    - name: Create secret-manager configuration
      ansible.builtin.template:
        src: secret-manager.yml.j2
        dest: "{{ secret_manager_config_dir }}/secret-manager.yml"
        mode: '0644'
        owner: "{{ secret_manager_service_user if secret_manager_service_user != 'root' else 'root' }}"

    # Setup SSL/TLS certificates if enabled
    - name: Ensure TLS directories exist
      ansible.builtin.file:
        path: "{{ secret_manager_config_dir }}/tls"
        state: directory
        mode: '0755'
      when: secret_manager_tls_enabled

    - name: Copy TLS certificates if provided
      ansible.builtin.copy:
        src: "{{ item.src }}"
        dest: "{{ secret_manager_config_dir }}/tls/{{ item.dest }}"
        mode: '0600'
      loop:
        - src: "{{ secret_manager_tls_cert_file }}"
          dest: "tls-cert.pem"
        - src: "{{ secret_manager_tls_key_file }}"
          dest: "tls-key.pem"
      when: secret_manager_tls_enabled and secret_manager_tls_cert_file and secret_manager_tls_key_file

    # Cleanup
    - name: Remove temporary download
      ansible.builtin.file:
        path: "/tmp/{{ secret_manager_binary_name }}"
        state: absent

    # Service status check
    - name: Check Secret Manager service status
      ansible.builtin.service:
        name: "{{ secret_manager_service_name }}"
        state: started
      register: service_status

    - name: Verify Secret Manager is running
      ansible.builtin.uri:
        url: http://localhost:{{ secret_manager_port }}/health
        method: GET
        timeout: 10
        status_code: 200
      register: health_check
      until: health_check is succeeded
      retries: 5
      delay: 5
      failed_when: false

    - name: Display installation result
      ansible.builtin.debug:
        msg: "Secret Manager has been successfully deployed on {{ ansible_nodename }}"