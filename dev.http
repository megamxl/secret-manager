### GET request to example server
POST localhost:8090/create
Content-Type: application/json

{
  "file_path": "C:\\Users\\maxl\\Documents\\test2.txt",
  "store_name" : "secondVault",
  "secret_wrapper": {
    "content": "<Context>\n   <Enviroment name=\"ENV_NAME\" value=\"{{ name }}\" type=\"java.lang.String\" override=\"false\" />\n</Context>",
    "secret_references": {
