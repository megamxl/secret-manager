### GET request to example server
POST localhost:8090/secret
Content-Type: application/json

{
  "name" : "test-secret1",
  "file_path": "C:\\Users\\maxl\\Documents\\test1.txt",
  "store_name" : "secondVault",
  "reroll_time" : "5s",
  "secret_wrapper": {
    "content": "<Context>\n   <Environment name=\"env.name\" value=\"{{ name }}\" type=\"java.lang.String\" override=\"false\" />\n</Context> \n",
    "secret_references": {
      "name": "global/name",
      "name2": "global/test/name"
    }
  }
}

###
PUT localhost:8090/secret
Content-Type: application/json

{
  "name" : "test-secret",
  "file_path": "C:\\Users\\maxl\\Documents\\test.txt",
  "store_name" : "secondVault",
  "reroll_time" : "5S",
  "secret_wrapper": {
    "content": "<Context>\n   <Environment name=\"env.name\" value=\"{{ name2 }}\" type=\"java.lang.String\" override=\"false\" />\n</Context> \n",
    "secret_references": {
      "name": "global/name",
      "name2": "global/test/name"
    }
  }
}

###
POST localhost:8090/secret
Content-Type: application/x-yaml

name: test-secret2
file_path: "C:\\Users\\maxl\\Documents\\test2.txt"
store_name: secondVault
reroll_time: 25s
secret_wrapper:
  content: |
    <Context>
       <Environment name="env.name" value="{{ name2 }}" type="java.lang.String" override="false" />
    </Context>
  secret_references:
    name: global/name
    name2: global/test/name



###
POST 10.0.0.59:8090/create
Content-Type: application/json

{
  "file_path": "/etc/tomcat10/Catalina/localhost/app.xml",
  "store_name": "vault",
  "secret_wrapper": {
    "content": "<Context>\n   <Environment name=\"env.name\" value=\"{{ name }}\" type=\"java.lang.String\" override=\"false\" />\n</Context> \n",
    "secret_references": {
      "name": "global/name",
      "name2": "global/test/name"
    }
  }
} 

